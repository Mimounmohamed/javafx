<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.example.controllers.AnimalsController"
      styleClass="content-root animals-root">

    <!-- ── Page header ───────────────────────────────────────────────── -->
    <HBox styleClass="zones-page-header" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="14" right="24" bottom="14" left="24" /></padding>
        <VBox spacing="1">
            <Label text="Smart Farm"  styleClass="zones-farm-name" />
            <Label text="Animals"     styleClass="zones-page-title" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="➕ Add Animal" onAction="#showAddAnimalDialog" styleClass="btn-primary" />
    </HBox>
    <Separator />

    <!-- ── Stat cards ────────────────────────────────────────────────── -->
    <HBox styleClass="zones-stats-row" spacing="12" fillHeight="true">
        <padding><Insets top="14" right="24" bottom="14" left="24" /></padding>

        <VBox styleClass="zones-stat-card" spacing="3" alignment="TOP_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label text="TOTAL ANIMALS"                styleClass="zones-stat-card-title" />
            <Label fx:id="statTotalAnimals" text="—"   styleClass="zones-stat-card-number" />
            <Label text="across all zones"             styleClass="zones-stat-card-sub" />
        </VBox>

        <VBox styleClass="zones-stat-card zones-stat-card-green" spacing="3" alignment="TOP_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label text="HEALTHY"                styleClass="zones-stat-card-title" />
            <Label fx:id="statHealthy" text="—"  styleClass="zones-stat-card-number" />
            <Label text="no issues"             styleClass="zones-stat-card-sub" />
        </VBox>

        <VBox styleClass="zones-stat-card animals-stat-card-amber" spacing="3" alignment="TOP_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label text="SICK"                styleClass="zones-stat-card-title" />
            <Label fx:id="statSick" text="—"  styleClass="zones-stat-card-number" />
            <Label text="need attention"     styleClass="zones-stat-card-sub" />
        </VBox>

        <VBox styleClass="zones-stat-card animals-stat-card-red" spacing="3" alignment="TOP_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label text="QUARANTINED"                styleClass="zones-stat-card-title" />
            <Label fx:id="statQuarantined" text="—"  styleClass="zones-stat-card-number" />
            <Label text="isolated from herd"        styleClass="zones-stat-card-sub" />
        </VBox>
    </HBox>

    <!-- ── Main split: animal list ‖ detail panel ────────────────────── -->
    <SplitPane VBox.vgrow="ALWAYS" dividerPositions="0.58" styleClass="zones-split">

        <!-- LEFT: filter row + table ─────────────────────────────────── -->
        <VBox styleClass="zones-list-panel">

            <!-- Combined search + filter row -->
            <HBox styleClass="animals-filter-row" alignment="CENTER_LEFT" spacing="8">
                <padding><Insets top="0" right="12" bottom="0" left="12" /></padding>
                <Label text="🔍" styleClass="zones-search-icon" />
                <TextField fx:id="searchField" promptText="Search name / species…"
                           styleClass="zones-search-field" HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="filterZone"   promptText="Zone"   styleClass="animals-filter-combo" prefWidth="140" />
                <ComboBox fx:id="filterHealth" promptText="Health" styleClass="animals-filter-combo" prefWidth="120" />
            </HBox>

            <TableView fx:id="animalTable" VBox.vgrow="ALWAYS" maxHeight="Infinity"
                       styleClass="zones-table">
                <columns>
                    <TableColumn fx:id="colId"      text="ID"      prefWidth="85"  />
                    <TableColumn fx:id="colName"    text="Name"    prefWidth="110" />
                    <TableColumn fx:id="colSpecies" text="Species" prefWidth="100" />
                    <TableColumn fx:id="colType"    text="Type"    prefWidth="95"  />
                    <TableColumn fx:id="colZone"    text="Zone"    prefWidth="130" />
                    <TableColumn fx:id="colHealth"  text="Health"  prefWidth="110" />
                </columns>
                <placeholder>
                    <Label text="No animals found — click ➕ Add Animal" styleClass="text-muted" />
                </placeholder>
            </TableView>

        </VBox>

        <!-- RIGHT: detail panel ─────────────────────────────────────── -->
        <ScrollPane fitToWidth="true" styleClass="detail-scroll zones-detail-scroll">
            <VBox fx:id="detailPanel" styleClass="detail-panel zones-detail-panel" spacing="8">
                <padding><Insets top="16" right="16" bottom="16" left="16" /></padding>
                <Label text="Select an animal to view details" styleClass="text-muted" />
            </VBox>
        </ScrollPane>

    </SplitPane>
</VBox>
