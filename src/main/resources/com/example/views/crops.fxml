<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.example.controllers.CropsController"
      styleClass="content-root animals-root">

    <!-- ── Page header ───────────────────────────────────────────────── -->
    <HBox styleClass="zones-page-header" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="14" right="24" bottom="14" left="24" /></padding>
        <VBox spacing="1">
            <Label text="Smart Farm" styleClass="zones-farm-name" />
            <Label text="Crops"      styleClass="zones-page-title" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="🌾 Add Crop" onAction="#showAddCropDialog" styleClass="btn-primary" />
    </HBox>

    <!-- ── Stats cards row ───────────────────────────────────────────── -->
    <HBox spacing="16"
          style="-fx-background-color: #F5F5F3; -fx-border-color: transparent transparent #e0e0e0 transparent; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

        <VBox HBox.hgrow="ALWAYS" spacing="4"
              style="-fx-background-color: #16A34A, #ffffff; -fx-background-insets: 0, 0 0 0 4; -fx-background-radius: 12, 0 12 12 0; -fx-border-width: 0; -fx-padding: 14 18; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.07), 8, 0, 0, 2);">
            <Label fx:id="statTotalCrops" text="—" styleClass="zones-kpi-value" />
            <Label text="TOTAL CROPS" styleClass="zones-kpi-label" />
            <Label text="registered" styleClass="zones-kpi-sub" />
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="4"
              style="-fx-background-color: #22C55E, #ffffff; -fx-background-insets: 0, 0 0 0 4; -fx-background-radius: 12, 0 12 12 0; -fx-border-width: 0; -fx-padding: 14 18; -fx-effect: dropshadow(three-pass-box, rgba(34,197,94,0.12), 8, 0, 0, 2);">
            <Label fx:id="statHarvestReady" text="—" styleClass="zones-kpi-value" />
            <Label text="HARVEST READY" styleClass="zones-kpi-label" />
            <Label text="ready to pick" styleClass="zones-kpi-sub" />
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="4"
              style="-fx-background-color: #3B82F6, #ffffff; -fx-background-insets: 0, 0 0 0 4; -fx-background-radius: 12, 0 12 12 0; -fx-border-width: 0; -fx-padding: 14 18; -fx-effect: dropshadow(three-pass-box, rgba(59,130,246,0.12), 8, 0, 0, 2);">
            <Label fx:id="statGrowing" text="—" styleClass="zones-kpi-value" />
            <Label text="GROWING" styleClass="zones-kpi-label" />
            <Label text="in progress" styleClass="zones-kpi-sub" />
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="4"
              style="-fx-background-color: #6366F1, #ffffff; -fx-background-insets: 0, 0 0 0 4; -fx-background-radius: 12, 0 12 12 0; -fx-border-width: 0; -fx-padding: 14 18; -fx-effect: dropshadow(three-pass-box, rgba(99,102,241,0.12), 8, 0, 0, 2);">
            <Label fx:id="statCropZones" text="—" styleClass="zones-kpi-value" />
            <Label text="CROP ZONES" styleClass="zones-kpi-label" />
            <Label text="active zones" styleClass="zones-kpi-sub" />
        </VBox>
    </HBox>

    <!-- ── Main split: list ‖ detail ─────────────────────────────────── -->
    <SplitPane VBox.vgrow="ALWAYS" dividerPositions="0.55" styleClass="zones-split">

        <!-- LEFT: filter row + table ─────────────────────────────────── -->
        <VBox styleClass="zones-list-panel">

            <HBox styleClass="animals-filter-row" alignment="CENTER_LEFT" spacing="8">
                <padding><Insets top="0" right="12" bottom="0" left="12" /></padding>
                <Label text="🔍" styleClass="zones-search-icon" />
                <TextField fx:id="searchField" promptText="Search variety…"
                           styleClass="zones-search-field" HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="filterZone"  promptText="Zone"  styleClass="animals-filter-combo" prefWidth="130" />
                <ComboBox fx:id="filterType"  promptText="Type"  styleClass="animals-filter-combo" prefWidth="100" />
                <ComboBox fx:id="filterStage" promptText="Stage" styleClass="animals-filter-combo" prefWidth="100" />
            </HBox>

            <TableView fx:id="cropTable" VBox.vgrow="ALWAYS" maxHeight="Infinity"
                       styleClass="zones-table">
                <columns>
                    <TableColumn fx:id="colCropId"   text="ID"         prefWidth="75"  />
                    <TableColumn fx:id="colVariety"   text="Variety"    prefWidth="130" />
                    <TableColumn fx:id="colType"      text="Type"       prefWidth="90"  />
                    <TableColumn fx:id="colStage"     text="Stage"      prefWidth="110" />
                    <TableColumn fx:id="colCropZone"  text="Zone"       prefWidth="120" />
                    <TableColumn fx:id="colYield"     text="Yield (kg)" prefWidth="90"  />
                </columns>
                <placeholder>
                    <Label text="No crops found — click 🌾 Add Crop" styleClass="text-muted" />
                </placeholder>
            </TableView>

        </VBox>

        <!-- RIGHT: detail outer (header + 3-tab panel) ──────────────── -->
        <VBox styleClass="animals-detail-outer">

            <!-- Dynamic header (avatar · name · stage pill · ghost btns) -->
            <VBox fx:id="detailHeaderPanel" styleClass="animals-detail-header-area">
                <padding><Insets top="0" right="0" bottom="0" left="0" /></padding>
            </VBox>

            <!-- 3-tab detail panel -->
            <TabPane tabClosingPolicy="UNAVAILABLE"
                     styleClass="animals-detail-tabs" VBox.vgrow="ALWAYS">

                <Tab text="Info">
                    <ScrollPane fitToWidth="true" styleClass="animals-tab-scroll">
                        <VBox fx:id="detailPanel" styleClass="animals-tab-vbox" spacing="0">
                            <padding><Insets top="14" right="16" bottom="16" left="16" /></padding>
                            <Label text="Select a crop to view details" styleClass="text-muted" />
                        </VBox>
                    </ScrollPane>
                </Tab>

                <Tab text="Yield">
                    <ScrollPane fitToWidth="true" styleClass="animals-tab-scroll">
                        <VBox fx:id="yieldPanel" styleClass="animals-tab-vbox" spacing="10">
                            <padding><Insets top="14" right="16" bottom="16" left="16" /></padding>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <Tab text="Actions">
                    <ScrollPane fitToWidth="true" styleClass="animals-tab-scroll">
                        <VBox fx:id="actionsPanel" styleClass="animals-tab-vbox" spacing="8">
                            <padding><Insets top="14" right="16" bottom="16" left="16" /></padding>
                        </VBox>
                    </ScrollPane>
                </Tab>

            </TabPane>

        </VBox>

    </SplitPane>
</VBox>
