<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.example.controllers.AquacultureController"
      styleClass="content-root animals-root">

    <!-- ── Page header ───────────────────────────────────────────────── -->
    <HBox styleClass="zones-page-header" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="14" right="24" bottom="14" left="24" /></padding>
        <VBox spacing="1">
            <Label text="Smart Farm"   styleClass="zones-farm-name" />
            <Label text="Aquaculture"  styleClass="zones-page-title" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="🐟 Add Species" onAction="#showAddSpeciesDialog" styleClass="btn-primary" />
    </HBox>

    <!-- ── Stats cards row ───────────────────────────────────────────── -->
    <HBox spacing="16" styleClass="zones-kpi-strip">
        <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>
        <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="kpi-card-stripe kpi-card-stripe-sky">
            <Label fx:id="statTotalSpecies" text="—" styleClass="zones-kpi-value" />
            <Label text="TOTAL SPECIES" styleClass="zones-kpi-label" />
            <Label text="registered" styleClass="zones-kpi-sub" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="kpi-card-stripe kpi-card-stripe-cyan">
            <Label fx:id="statTotalStock" text="—" styleClass="zones-kpi-value" />
            <Label text="TOTAL STOCK" styleClass="zones-kpi-label" />
            <Label text="live specimens" styleClass="zones-kpi-sub" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="kpi-card-stripe kpi-card-stripe-purple">
            <Label fx:id="statHarvested" text="—" styleClass="zones-kpi-value" />
            <Label text="HARVESTED" styleClass="zones-kpi-label" />
            <Label text="total count" styleClass="zones-kpi-sub" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="kpi-card-stripe kpi-card-stripe-violet">
            <Label fx:id="statAquaZones" text="—" styleClass="zones-kpi-value" />
            <Label text="AQUA ZONES" styleClass="zones-kpi-label" />
            <Label text="active zones" styleClass="zones-kpi-sub" />
        </VBox>
    </HBox>

    <!-- ── Main split: list ‖ detail ─────────────────────────────────── -->
    <SplitPane VBox.vgrow="ALWAYS" dividerPositions="0.55" styleClass="zones-split">

        <!-- LEFT: filter row + table ─────────────────────────────────── -->
        <VBox styleClass="zones-list-panel">

            <HBox styleClass="animals-filter-row" alignment="CENTER_LEFT" spacing="8">
                <padding><Insets top="0" right="12" bottom="0" left="12" /></padding>
                <Label text="🔍" styleClass="zones-search-icon" />
                <TextField fx:id="searchField" promptText="Search species…"
                           styleClass="zones-search-field" HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="filterZone" promptText="Zone" styleClass="animals-filter-combo" prefWidth="130" />
            </HBox>

            <TableView fx:id="speciesTable" VBox.vgrow="ALWAYS" maxHeight="Infinity"
                       styleClass="zones-table">
                <columns>
                    <TableColumn fx:id="colSpeciesId" text="ID"         prefWidth="75"  />
                    <TableColumn fx:id="colName"      text="Species"     prefWidth="140" />
                    <TableColumn fx:id="colAquaZone"  text="Zone"        prefWidth="130" />
                    <TableColumn fx:id="colStock"     text="Stock"       prefWidth="80"  />
                    <TableColumn fx:id="colHarvested" text="Harvested"   prefWidth="90"  />
                    <TableColumn fx:id="colSurvival"  text="Survival %"  prefWidth="90"  />
                </columns>
                <placeholder>
                    <Label text="No species found — click 🐟 Add Species" styleClass="text-muted" />
                </placeholder>
            </TableView>

        </VBox>

        <!-- RIGHT: detail outer (header + 3-tab panel) ──────────────── -->
        <VBox styleClass="animals-detail-outer">

            <!-- Dynamic header (avatar · name · stock pill · ghost btns) -->
            <VBox fx:id="detailHeaderPanel" styleClass="animals-detail-header-area">
                <padding><Insets top="0" right="0" bottom="0" left="0" /></padding>
            </VBox>

            <!-- 3-tab detail panel -->
            <TabPane tabClosingPolicy="UNAVAILABLE"
                     styleClass="animals-detail-tabs" VBox.vgrow="ALWAYS">

                <Tab text="Info">
                    <ScrollPane fitToWidth="true" styleClass="animals-tab-scroll">
                        <VBox fx:id="detailPanel" styleClass="animals-tab-vbox" spacing="0">
                            <padding><Insets top="14" right="16" bottom="16" left="16" /></padding>
                            <Label text="Select a species to view details" styleClass="text-muted" />
                        </VBox>
                    </ScrollPane>
                </Tab>

                <Tab text="Harvest">
                    <ScrollPane fitToWidth="true" styleClass="animals-tab-scroll">
                        <VBox fx:id="harvestPanel" styleClass="animals-tab-vbox" spacing="10">
                            <padding><Insets top="14" right="16" bottom="16" left="16" /></padding>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <Tab text="Actions">
                    <ScrollPane fitToWidth="true" styleClass="animals-tab-scroll">
                        <VBox fx:id="actionsPanel" styleClass="animals-tab-vbox" spacing="8">
                            <padding><Insets top="14" right="16" bottom="16" left="16" /></padding>
                        </VBox>
                    </ScrollPane>
                </Tab>

            </TabPane>

        </VBox>

    </SplitPane>
</VBox>
