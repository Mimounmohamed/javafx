<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.example.controllers.MainController"
            styleClass="root-pane">

    <!-- ══ Left Sidebar ══════════════════════════════════════════════ -->
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar" prefWidth="240" minWidth="64" maxWidth="240">

            <Label fx:id="logoLabel" text="🌾  FarmManager" styleClass="sidebar-logo" maxWidth="Infinity" />
            <Separator styleClass="sidebar-sep" />

            <Button fx:id="toggleBtn" onAction="#toggleSidebar" text="☰"
                    styleClass="nav-btn" maxWidth="Infinity" />
            <Separator styleClass="sidebar-sep" />

            <Button fx:id="btnDashboard" onAction="#navDashboard"
                    text="📊   Dashboard" styleClass="nav-btn" maxWidth="Infinity" />
            <Button fx:id="btnZones"     onAction="#navZones"
                    text="🗺   Zones"     styleClass="nav-btn" maxWidth="Infinity" />
            <Button fx:id="btnAnimals"   onAction="#navAnimals"
                    text="🐄   Animals"   styleClass="nav-btn" maxWidth="Infinity" />
            <Button fx:id="btnSensors"   onAction="#navSensors"
                    text="📡   Sensors"   styleClass="nav-btn" maxWidth="Infinity" />
            <Button fx:id="btnAlerts"    onAction="#navAlerts"
                    text="🔔   Alerts"    styleClass="nav-btn" maxWidth="Infinity" />
            <Button fx:id="btnReports"    onAction="#navReports"
                    text="📋   Reports"    styleClass="nav-btn" maxWidth="Infinity" />
            <Button fx:id="btnSimulation" onAction="#navSimulation"
                    text="⏩   Simulation" styleClass="nav-btn" maxWidth="Infinity" />

            <Region VBox.vgrow="ALWAYS" />
            <Separator styleClass="sidebar-sep" />

            <Button fx:id="btnSettings"  onAction="#navSettings"
                    text="⚙   Settings"  styleClass="nav-btn" maxWidth="Infinity" />
        </VBox>
    </left>

    <!-- ══ Top Bar ═══════════════════════════════════════════════════ -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="0" right="20" bottom="0" left="20" /></padding>
            <Label fx:id="farmNameLabel" styleClass="topbar-title" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="clockLabel" styleClass="topbar-clock" text="..." />
            <Button onAction="#navAlerts" styleClass="topbar-bell-btn" text="🔔" />
            <Label fx:id="alertBadge" styleClass="topbar-alert-badge"
                   text="0" visible="false" managed="false" />
        </HBox>
    </top>

    <!-- Center will be set programmatically by SceneManager.navigateTo() -->

</BorderPane>
