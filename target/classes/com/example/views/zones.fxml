<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.example.controllers.ZonesController"
      styleClass="content-root zones-root">

    <!-- ── Page header ───────────────────────────────────────────────── -->
    <HBox styleClass="zones-page-header" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="14" right="24" bottom="14" left="24" /></padding>
        <VBox spacing="1">
            <Label text="Smart Farm" styleClass="zones-farm-name" />
            <Label text="Zone Management" styleClass="zones-page-title" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="➕ Add Zone" onAction="#showAddZoneDialog" styleClass="btn-primary" />
        <!-- Kept for @FXML binding — visual activate/suspend live in the detail panel -->
        <Button text="✔ Activate" onAction="#activateZone" styleClass="btn-ghost"
                visible="false" managed="false" />
        <Button text="⏸ Suspend"  onAction="#suspendZone"  styleClass="btn-ghost"
                visible="false" managed="false" />
    </HBox>
    <Separator />

    <!-- ── Stat cards ────────────────────────────────────────────────── -->
    <HBox styleClass="zones-stats-row" spacing="12" fillHeight="true">
        <padding><Insets top="14" right="24" bottom="14" left="24" /></padding>

        <VBox styleClass="zones-stat-card" spacing="3" alignment="TOP_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label text="TOTAL ZONES"             styleClass="zones-stat-card-title" />
            <Label fx:id="statTotalZones" text="—" styleClass="zones-stat-card-number" />
            <Label fx:id="statTotalSub"  text="all types" styleClass="zones-stat-card-sub" />
        </VBox>

        <VBox styleClass="zones-stat-card zones-stat-card-green" spacing="3" alignment="TOP_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label text="ACTIVE"                   styleClass="zones-stat-card-title" />
            <Label fx:id="statActiveZones" text="—" styleClass="zones-stat-card-number" />
            <Label fx:id="statActiveSub"  text="all running" styleClass="zones-stat-card-sub" />
        </VBox>

        <VBox styleClass="zones-stat-card" spacing="3" alignment="TOP_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label text="LIVESTOCK"                    styleClass="zones-stat-card-title" />
            <Label fx:id="statLivestockCount" text="—" styleClass="zones-stat-card-number" />
            <Label fx:id="statLivestockSub"  text="no alerts" styleClass="zones-stat-card-sub" />
        </VBox>

        <VBox styleClass="zones-stat-card" spacing="3" alignment="TOP_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label text="CROP"                    styleClass="zones-stat-card-title" />
            <Label fx:id="statCropCount" text="—" styleClass="zones-stat-card-number" />
            <Label fx:id="statCropSub"  text="no alerts" styleClass="zones-stat-card-sub" />
        </VBox>

        <VBox styleClass="zones-stat-card" spacing="3" alignment="TOP_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label text="AQUACULTURE"              styleClass="zones-stat-card-title" />
            <Label fx:id="statAquaCount" text="—" styleClass="zones-stat-card-number" />
            <Label fx:id="statAquaSub"  text="no alerts" styleClass="zones-stat-card-sub" />
        </VBox>
    </HBox>

    <!-- ── Distress alert banner (hidden until wired in controller) ───── -->
    <HBox fx:id="distressBanner" styleClass="zones-distress-banner"
          alignment="CENTER_LEFT" spacing="10"
          visible="false" managed="false">
        <padding><Insets top="10" right="16" bottom="10" left="16" /></padding>
        <Label text="⚠" styleClass="zones-distress-icon" />
        <Label fx:id="distressBannerText"
               text="Sensor distress detected — animal showing anomaly"
               styleClass="zones-distress-text" HBox.hgrow="ALWAYS" wrapText="true" />
        <Hyperlink text="View →" styleClass="zones-distress-link" />
    </HBox>

    <!-- ── Main split: zone list ‖ detail panel ──────────────────────── -->
    <SplitPane VBox.vgrow="ALWAYS" dividerPositions="0.52" styleClass="zones-split">

        <!-- LEFT: search + zone-type tabs ────────────────────────────── -->
        <VBox styleClass="zones-list-panel">

            <!-- Inline search row (no separate toolbar) -->
            <HBox styleClass="zones-search-row" alignment="CENTER_LEFT" spacing="8">
                <padding><Insets top="0" right="12" bottom="0" left="12" /></padding>
                <Label text="🔍" styleClass="zones-search-icon" />
                <TextField fx:id="searchField" promptText="Search zones…"
                           styleClass="zones-search-field" HBox.hgrow="ALWAYS" />
            </HBox>

            <TabPane tabClosingPolicy="UNAVAILABLE" styleClass="zone-tabs zones-zone-tabs" VBox.vgrow="ALWAYS">

                <Tab text="🐄  Livestock">
                    <TableView fx:id="livestockTable" maxHeight="Infinity"
                               styleClass="zones-table">
                        <columns>
                            <TableColumn fx:id="lsColCode"    text="Code"    prefWidth="65"  />
                            <TableColumn fx:id="lsColName"    text="Name"    prefWidth="150" />
                            <TableColumn fx:id="lsColType"    text="Type"    prefWidth="100" />
                            <TableColumn fx:id="lsColAnimals" text="Animals" prefWidth="80"  />
                            <TableColumn fx:id="lsColStatus"  text="Status"  prefWidth="90" />
                        </columns>
                        <placeholder>
                            <Label text="No livestock zones — click ➕ Add Zone" styleClass="text-muted" />
                        </placeholder>
                    </TableView>
                </Tab>

                <Tab text="🌾  Crop">
                    <TableView fx:id="cropTable" maxHeight="Infinity"
                               styleClass="zones-table">
                        <columns>
                            <TableColumn fx:id="crColCode"    text="Code"       prefWidth="65"  />
                            <TableColumn fx:id="crColName"    text="Name"       prefWidth="150" />
                            <TableColumn fx:id="crColFields"  text="Crops"      prefWidth="60"  />
                            <TableColumn fx:id="crColSurface" text="Surface(ha)" prefWidth="95" />
                            <TableColumn fx:id="crColStatus"  text="Status"     prefWidth="90" />
                        </columns>
                        <placeholder>
                            <Label text="No crop zones — click ➕ Add Zone" styleClass="text-muted" />
                        </placeholder>
                    </TableView>
                </Tab>

                <Tab text="🐟  Aquaculture">
                    <TableView fx:id="aquaTable" maxHeight="Infinity"
                               styleClass="zones-table">
                        <columns>
                            <TableColumn fx:id="aqColCode"    text="Code"    prefWidth="65"  />
                            <TableColumn fx:id="aqColName"    text="Name"    prefWidth="150" />
                            <TableColumn fx:id="aqColSpecies" text="Species" prefWidth="70"  />
                            <TableColumn fx:id="aqColStatus"  text="Status"  prefWidth="90" />
                        </columns>
                        <placeholder>
                            <Label text="No aquaculture zones — click ➕ Add Zone" styleClass="text-muted" />
                        </placeholder>
                    </TableView>
                </Tab>

            </TabPane>
        </VBox>

        <!-- RIGHT: persistent header + 2-tab detail panel ───────────── -->
        <VBox styleClass="zones-detail-outer">

            <!-- Zone name header (hidden until a zone is selected) -->
            <VBox fx:id="zoneDetailHeader" styleClass="zones-detail-header-area"
                  visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <padding><Insets top="12" right="12" bottom="10" left="16" /></padding>
                    <Label fx:id="zoneDetailName" styleClass="zones-detail-zone-name" HBox.hgrow="ALWAYS" />
                    <Button text="✕" onAction="#closeDetail" styleClass="btn-ghost" />
                </HBox>
            </VBox>

            <!-- Details / Actions tab pane -->
            <TabPane fx:id="zoneDetailTabs" tabClosingPolicy="UNAVAILABLE"
                     styleClass="animals-detail-tabs" VBox.vgrow="ALWAYS"
                     visible="false" managed="false">

                <Tab text="Details">
                    <ScrollPane fitToWidth="true" styleClass="animals-tab-scroll">
                        <VBox fx:id="detailPanel" styleClass="detail-panel zones-detail-panel animals-tab-vbox" spacing="0">
                            <padding><Insets top="14" right="16" bottom="16" left="16" /></padding>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <Tab text="Actions">
                    <ScrollPane fitToWidth="true" styleClass="animals-tab-scroll">
                        <VBox fx:id="actionsPanel" styleClass="zones-detail-panel animals-tab-vbox" spacing="6">
                            <padding><Insets top="14" right="16" bottom="16" left="16" /></padding>
                        </VBox>
                    </ScrollPane>
                </Tab>

            </TabPane>

            <!-- Empty-state placeholder -->
            <VBox fx:id="zoneDetailPlaceholder" VBox.vgrow="ALWAYS" alignment="CENTER">
                <Label text="Select a zone to view details" styleClass="text-muted" />
            </VBox>

        </VBox>

    </SplitPane>
</VBox>
