<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>

<ScrollPane fitToWidth="true" styleClass="content-scroll"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.example.controllers.DashboardController">

    <VBox spacing="20" styleClass="content-root">
        <padding><Insets top="24" right="24" bottom="32" left="24" /></padding>

        <!-- Page title -->
        <Label text="Dashboard" styleClass="page-title" />

        <!-- ── KPI Cards row 1 ────────────────────────────────────── -->
        <HBox spacing="16">
            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6" alignment="TOP_LEFT">
                <Label text="🐄" styleClass="kpi-icon" />
                <Label fx:id="kpiAnimals" text="—" styleClass="kpi-value" />
                <Label text="Total Animals"  styleClass="kpi-label" />
            </VBox>
            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6" alignment="TOP_LEFT">
                <Label text="🤒" styleClass="kpi-icon" />
                <Label fx:id="kpiSickAnimals" text="—" styleClass="kpi-value" />
                <Label text="Sick Animals"   styleClass="kpi-label" />
            </VBox>
            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6" alignment="TOP_LEFT">
                <Label text="🗺" styleClass="kpi-icon" />
                <Label fx:id="kpiZones" text="—" styleClass="kpi-value" />
                <Label text="Active Zones"   styleClass="kpi-label" />
            </VBox>
            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6" alignment="TOP_LEFT">
                <Label text="📊" styleClass="kpi-icon" />
                <Label fx:id="kpiTotalZones" text="—" styleClass="kpi-value" />
                <Label text="Total Zones"    styleClass="kpi-label" />
            </VBox>
        </HBox>

        <!-- ── KPI Cards row 2 ────────────────────────────────────── -->
        <HBox spacing="16">
            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6" alignment="TOP_LEFT">
                <Label text="📡" styleClass="kpi-icon" />
                <Label fx:id="kpiSensors" text="—" styleClass="kpi-value" />
                <Label text="Active Sensors" styleClass="kpi-label" />
            </VBox>
            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6" alignment="TOP_LEFT">
                <Label text="🔔" styleClass="kpi-icon" />
                <Label fx:id="kpiAlerts" text="—" styleClass="kpi-value" />
                <Label text="Open Alerts"    styleClass="kpi-label" />
            </VBox>
            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6" alignment="TOP_LEFT">
                <Label text="🌾" styleClass="kpi-icon" />
                <Label fx:id="kpiFields" text="—" styleClass="kpi-value" />
                <Label text="Crop Fields"    styleClass="kpi-label" />
            </VBox>
            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6" alignment="TOP_LEFT">
                <Label text="🐟" styleClass="kpi-icon" />
                <Label fx:id="kpiSpecies" text="—" styleClass="kpi-value" />
                <Label text="Aqua Species"   styleClass="kpi-label" />
            </VBox>
        </HBox>

        <!-- ── Farm Summary ───────────────────────────────────────── -->
        <VBox styleClass="kpi-card" spacing="6">
            <Label text="Farm Summary" styleClass="card-title" />
            <Label fx:id="lblFarmSummary" text="—" styleClass="text-muted" wrapText="true" />
        </VBox>

        <!-- ── Chart + Recent Alerts ──────────────────────────────── -->
        <HBox spacing="16">
            <!-- Production chart (built in controller) -->
            <VBox fx:id="chartContainer" styleClass="kpi-card" HBox.hgrow="ALWAYS"
                  spacing="12" minHeight="300">
                <Label text="Production Overview" styleClass="card-title" />
            </VBox>

            <!-- Recent alerts table -->
            <VBox styleClass="kpi-card" prefWidth="400" spacing="12">
                <Label text="Recent Alerts" styleClass="card-title" />
                <TableView fx:id="recentAlertsTable" VBox.vgrow="ALWAYS" maxHeight="280">
                    <columns>
                        <TableColumn fx:id="colAlertTime"     text="Date"     prefWidth="90"  />
                        <TableColumn fx:id="colAlertSeverity" text="Severity" prefWidth="80"  />
                        <TableColumn fx:id="colAlertMsg"      text="Message"  prefWidth="200" />
                    </columns>
                    <placeholder>
                        <Label text="No alerts" styleClass="text-muted" />
                    </placeholder>
                </TableView>
            </VBox>
        </HBox>

        <!-- ── Quick Actions ──────────────────────────────────────── -->
        <VBox styleClass="kpi-card" spacing="12">
            <Label text="Quick Actions" styleClass="card-title" />
            <HBox spacing="12">
                <Button text="+ Add Animal"          onAction="#quickAddAnimal"   styleClass="btn-primary" />
                <Button text="+ Add Zone"            onAction="#quickAddZone"     styleClass="btn-primary" />
                <Button text="&#127806; Add Crop"    onAction="#quickAddCrop"     styleClass="btn-secondary" />
                <Button text="&#128031; Add Aqua Species" onAction="#quickAddAqua" styleClass="btn-secondary" />
                <Button text="&#128203; View Reports" onAction="#quickViewReports" styleClass="btn-secondary" />
            </HBox>
        </VBox>

    </VBox>
</ScrollPane>
