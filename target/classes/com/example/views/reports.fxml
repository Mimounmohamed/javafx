<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.example.controllers.ReportsController"
      styleClass="content-root">

    <!-- ── Page header ──────────────────────────────────────────────────── -->
    <HBox styleClass="zones-page-header" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="14" right="24" bottom="14" left="24" /></padding>
        <VBox spacing="1">
            <Label fx:id="farmNameLabel" text="Smart Farm" styleClass="zones-farm-name" />
            <Label text="Reports &amp; Analytics" styleClass="zones-page-title" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="farmSubLabel" text="" styleClass="text-muted" />
    </HBox>

    <!-- ── KPI strip ────────────────────────────────────────────────────── -->
    <HBox spacing="16" styleClass="zones-kpi-strip">
        <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

        <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="kpi-card-stripe kpi-card-stripe-indigo">
            <Label text="ZONES" styleClass="zones-kpi-label" />
            <Label fx:id="kpiZones" text="—" styleClass="zones-kpi-value" />
            <Label text="all types" styleClass="zones-kpi-sub" />
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="kpi-card-stripe kpi-card-stripe-green">
            <Label text="ANIMALS" styleClass="zones-kpi-label" />
            <Label fx:id="kpiAnimals" text="—" styleClass="zones-kpi-value" />
            <Label text="registered" styleClass="zones-kpi-sub" />
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="kpi-card-stripe kpi-card-stripe-red">
            <Label text="ACTIVE ALERTS" styleClass="zones-kpi-label" />
            <Label fx:id="kpiAlerts" text="—" styleClass="zones-kpi-value" />
            <Label text="unresolved" styleClass="zones-kpi-sub" />
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="kpi-card-stripe kpi-card-stripe-amber">
            <Label text="SENSORS" styleClass="zones-kpi-label" />
            <Label fx:id="kpiSensors" text="—" styleClass="zones-kpi-value" />
            <Label text="monitoring" styleClass="zones-kpi-sub" />
        </VBox>

    </HBox>

    <!-- ── Main body: left nav sidebar + right content ──────────────────── -->
    <HBox VBox.vgrow="ALWAYS">

        <!-- LEFT nav ───────────────────────────────────────────────────── -->
        <VBox styleClass="zones-list-panel" minWidth="196" maxWidth="196" prefWidth="196">
            <padding><Insets top="14" right="8" bottom="14" left="8" /></padding>

            <Label text="SECTIONS" styleClass="zones-kpi-label">
                <padding><Insets top="0" right="8" bottom="8" left="8" /></padding>
            </Label>

            <Button fx:id="btnOverview"    text="📊  Farm Overview"   maxWidth="Infinity" onAction="#showOverview"    styleClass="nav-btn" />
            <Button fx:id="btnLivestock"   text="🐄  Livestock"       maxWidth="Infinity" onAction="#showLivestock"   styleClass="nav-btn" />
            <Button fx:id="btnCrops"       text="🌾  Crops"           maxWidth="Infinity" onAction="#showCrops"       styleClass="nav-btn" />
            <Button fx:id="btnAquaculture" text="🐟  Aquaculture"     maxWidth="Infinity" onAction="#showAquaculture" styleClass="nav-btn" />
            <Button fx:id="btnAlerts"      text="🔔  Alerts"          maxWidth="Infinity" onAction="#showAlerts"      styleClass="nav-btn" />
            <Button fx:id="btnSensors"     text="📡  Sensor History"  maxWidth="Infinity" onAction="#showSensors"     styleClass="nav-btn" />

            <Region VBox.vgrow="ALWAYS" />
            <Separator />
            <Button fx:id="btnExport"      text="📄  Export PDF"      maxWidth="Infinity" onAction="#showExport"      styleClass="nav-btn" />
        </VBox>

        <Separator orientation="VERTICAL" />

        <!-- RIGHT content area ─────────────────────────────────────────── -->
        <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true" fitToHeight="false"
                    styleClass="content-scroll">
            <VBox fx:id="contentArea" spacing="20">
                <padding><Insets top="24" right="24" bottom="24" left="24" /></padding>
            </VBox>
        </ScrollPane>

    </HBox>

</VBox>
