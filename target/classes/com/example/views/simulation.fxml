<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>

<ScrollPane fitToWidth="true" styleClass="content-scroll"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.example.controllers.SimulationController">

    <VBox spacing="20" styleClass="content-root">
        <padding><Insets top="24" right="24" bottom="32" left="24" /></padding>

        <!-- ── Header ───────────────────────────────────────────────── -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <Label text="Simulation" styleClass="page-title" HBox.hgrow="ALWAYS" />
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label fx:id="simDateLabel" styleClass="topbar-clock" text="—" />
                <Label fx:id="simDayLabel"  styleClass="text-muted"   text="Not started" />
            </VBox>
        </HBox>

        <!-- ── Step controls ────────────────────────────────────────── -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Button text="+1 Day"    onAction="#stepOneDay"    styleClass="btn-primary"   minWidth="100" />
            <Button text="+7 Days"   onAction="#stepOneWeek"   styleClass="btn-primary"   minWidth="100" />
            <Button text="+30 Days"  onAction="#stepOneMonth"  styleClass="btn-primary"   minWidth="100" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Reset"     onAction="#resetSim"      styleClass="btn-secondary" minWidth="80"  />
        </HBox>

        <Separator />

        <!-- ── Last-step KPI summary ─────────────────────────────────── -->
        <Label text="LAST STEP SUMMARY" styleClass="section-title" />
        <HBox spacing="16">
            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6" alignment="TOP_LEFT">
                <Label text="🥛" styleClass="kpi-icon" />
                <Label fx:id="kpiMilk" text="—" styleClass="kpi-value" />
                <Label text="Milk Collected" styleClass="kpi-label" />
            </VBox>
            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6" alignment="TOP_LEFT">
                <Label text="🥚" styleClass="kpi-icon" />
                <Label fx:id="kpiEggs" text="—" styleClass="kpi-value" />
                <Label text="Eggs" styleClass="kpi-label" />
            </VBox>
            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6" alignment="TOP_LEFT">
                <Label text="🌾" styleClass="kpi-icon" />
                <Label fx:id="kpiHarvests" text="—" styleClass="kpi-value" />
                <Label text="Harvests" styleClass="kpi-label" />
            </VBox>
            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6" alignment="TOP_LEFT">
                <Label text="🤒" styleClass="kpi-icon" />
                <Label fx:id="kpiHealthEvents" text="—" styleClass="kpi-value" />
                <Label text="Health Events" styleClass="kpi-label" />
            </VBox>
            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6" alignment="TOP_LEFT">
                <Label text="🔔" styleClass="kpi-icon" />
                <Label fx:id="kpiAlerts" text="—" styleClass="kpi-value" />
                <Label text="New Alerts" styleClass="kpi-label" />
            </VBox>
            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="6" alignment="TOP_LEFT">
                <Label text="💀" styleClass="kpi-icon" />
                <Label fx:id="kpiMortality" text="—" styleClass="kpi-value" />
                <Label text="Mortality" styleClass="kpi-label" />
            </VBox>
        </HBox>

        <Separator />

        <!-- ── Quick navigation ───────────────────────────────────────── -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="VIEW UPDATED DATA:" styleClass="section-title" />
            <Button text="📋  Reports"  onAction="#goToReports" styleClass="btn-secondary" />
            <Button text="📡  Sensors"  onAction="#goToSensors" styleClass="btn-secondary" />
            <Button text="🐄  Animals"  onAction="#goToAnimals" styleClass="btn-secondary" />
        </HBox>

        <Separator />

        <!-- ── Activity log ──────────────────────────────────────────── -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <Label text="ACTIVITY LOG" styleClass="section-title" HBox.hgrow="ALWAYS" />
            <Button text="Clear" onAction="#clearLog" styleClass="btn-secondary" />
        </HBox>

        <ListView fx:id="activityLog" styleClass="event-list" prefHeight="420" />

    </VBox>
</ScrollPane>
