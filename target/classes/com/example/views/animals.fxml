<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.example.controllers.AnimalsController"
      styleClass="content-root animals-root">

    <!-- ── Page header ───────────────────────────────────────────────── -->
    <HBox styleClass="zones-page-header" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="14" right="24" bottom="14" left="24" /></padding>
        <VBox spacing="1">
            <Label text="Smart Farm" styleClass="zones-farm-name" />
            <Label text="Animals"    styleClass="zones-page-title" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="➕ Add Animal" onAction="#showAddAnimalDialog" styleClass="btn-primary" />
    </HBox>

    <!-- ── Stats cards row ───────────────────────────────────────────── -->
    <HBox spacing="16" styleClass="zones-kpi-strip">
        <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

        <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="kpi-card-stripe kpi-card-stripe-indigo">
            <Label fx:id="statTotalAnimals" text="—" styleClass="zones-kpi-value" />
            <Label text="TOTAL ANIMALS" styleClass="zones-kpi-label" />
            <Label text="registered" styleClass="zones-kpi-sub" />
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="kpi-card-stripe kpi-card-stripe-green">
            <Label fx:id="statHealthy" text="—" styleClass="zones-kpi-value" />
            <Label text="HEALTHY" styleClass="zones-kpi-label" />
            <Label text="no issues" styleClass="zones-kpi-sub" />
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="kpi-card-stripe kpi-card-stripe-red">
            <Label fx:id="statSick" text="—" styleClass="zones-kpi-value" />
            <Label text="SICK" styleClass="zones-kpi-label" />
            <Label text="need attention" styleClass="zones-kpi-sub" />
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="kpi-card-stripe kpi-card-stripe-amber">
            <Label fx:id="statQuarantined" text="—" styleClass="zones-kpi-value" />
            <Label text="QUARANTINED" styleClass="zones-kpi-label" />
            <Label text="isolated" styleClass="zones-kpi-sub" />
        </VBox>
    </HBox>

    <!-- ── Main split: list ‖ detail ─────────────────────────────────── -->
    <SplitPane VBox.vgrow="ALWAYS" dividerPositions="0.55" styleClass="zones-split">

        <!-- LEFT: filter row + table ─────────────────────────────────── -->
        <VBox styleClass="zones-list-panel">

            <HBox styleClass="animals-filter-row" alignment="CENTER_LEFT" spacing="8">
                <padding><Insets top="0" right="12" bottom="0" left="12" /></padding>
                <Label text="🔍" styleClass="zones-search-icon" />
                <TextField fx:id="searchField" promptText="Search name / species…"
                           styleClass="zones-search-field" HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="filterZone"   promptText="Zone"   styleClass="animals-filter-combo" prefWidth="130" />
                <ComboBox fx:id="filterHealth" promptText="Health" styleClass="animals-filter-combo" prefWidth="110" />
            </HBox>

            <TableView fx:id="animalTable" VBox.vgrow="ALWAYS" maxHeight="Infinity"
                       styleClass="zones-table">
                <columns>
                    <TableColumn fx:id="colId"      text="ID"      prefWidth="85"  />
                    <TableColumn fx:id="colName"    text="Name"    prefWidth="110" />
                    <TableColumn fx:id="colSpecies" text="Species" prefWidth="100" />
                    <TableColumn fx:id="colType"    text="Type"    prefWidth="95"  />
                    <TableColumn fx:id="colZone"    text="Zone"    prefWidth="130" />
                    <TableColumn fx:id="colHealth"  text="Health"  prefWidth="110" />
                </columns>
                <placeholder>
                    <Label text="No animals found — click ➕ Add Animal" styleClass="text-muted" />
                </placeholder>
            </TableView>

        </VBox>

        <!-- RIGHT: detail outer (header + 3-tab panel) ──────────────── -->
        <VBox styleClass="animals-detail-outer">

            <!-- Dynamic header (avatar · name · health pill · ghost btns) -->
            <VBox fx:id="detailHeaderPanel" styleClass="animals-detail-header-area">
                <padding><Insets top="0" right="0" bottom="0" left="0" /></padding>
            </VBox>

            <!-- 3-tab detail panel -->
            <TabPane tabClosingPolicy="UNAVAILABLE"
                     styleClass="animals-detail-tabs" VBox.vgrow="ALWAYS">

                <Tab text="Info">
                    <ScrollPane fitToWidth="true" styleClass="animals-tab-scroll">
                        <VBox fx:id="detailPanel" styleClass="animals-tab-vbox" spacing="0">
                            <padding><Insets top="14" right="16" bottom="16" left="16" /></padding>
                            <Label text="Select an animal to view details" styleClass="text-muted" />
                        </VBox>
                    </ScrollPane>
                </Tab>

                <Tab text="Sensors">
                    <ScrollPane fitToWidth="true" styleClass="animals-tab-scroll">
                        <VBox fx:id="sensorsPanel" styleClass="animals-tab-vbox" spacing="10">
                            <padding><Insets top="14" right="16" bottom="16" left="16" /></padding>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <Tab text="Actions">
                    <ScrollPane fitToWidth="true" styleClass="animals-tab-scroll">
                        <VBox fx:id="actionsPanel" styleClass="animals-tab-vbox" spacing="8">
                            <padding><Insets top="14" right="16" bottom="16" left="16" /></padding>
                        </VBox>
                    </ScrollPane>
                </Tab>

            </TabPane>

        </VBox>

    </SplitPane>
</VBox>
