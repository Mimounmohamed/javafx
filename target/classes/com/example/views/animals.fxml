<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.example.controllers.AnimalsController"
      styleClass="content-root">

    <!-- ── Header ───────────────────────────────────────────────────── -->
    <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="20" right="24" bottom="16" left="24" /></padding>
        <Label text="Animals" styleClass="page-title" />
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="searchField" promptText="Search name / species…"
                   styleClass="search-field" prefWidth="200" />
        <ComboBox fx:id="filterZone"   promptText="Filter by Zone"   styleClass="filter-combo" prefWidth="160" />
        <ComboBox fx:id="filterHealth" promptText="Filter by Health" styleClass="filter-combo" prefWidth="150" />
        <Button text="➕ Add Animal" onAction="#showAddAnimalDialog" styleClass="btn-primary" />
    </HBox>
    <Separator />

    <!-- ── Stats bar ────────────────────────────────────────────────── -->
    <HBox styleClass="stats-bar" spacing="12" alignment="CENTER_LEFT">
        <padding><Insets top="12" right="24" bottom="12" left="24" /></padding>
        <VBox styleClass="stat-card stat-accent-blue" spacing="2" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label fx:id="statTotalAnimals" text="—" styleClass="stat-value" />
            <Label text="Total Animals" styleClass="stat-label" />
        </VBox>
        <VBox styleClass="stat-card stat-accent-green" spacing="2" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label fx:id="statHealthy" text="—" styleClass="stat-value" />
            <Label text="Healthy" styleClass="stat-label" />
        </VBox>
        <VBox styleClass="stat-card stat-accent-yellow" spacing="2" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label fx:id="statSick" text="—" styleClass="stat-value" />
            <Label text="Sick" styleClass="stat-label" />
        </VBox>
        <VBox styleClass="stat-card stat-accent-red" spacing="2" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label fx:id="statQuarantined" text="—" styleClass="stat-value" />
            <Label text="Quarantined" styleClass="stat-label" />
        </VBox>
    </HBox>
    <Separator />

    <!-- ── Table + Detail ─────────────────────────────────────────── -->
    <SplitPane VBox.vgrow="ALWAYS" dividerPositions="0.58">

        <TableView fx:id="animalTable" maxHeight="Infinity">
            <columns>
                <TableColumn fx:id="colId"      text="ID"      prefWidth="85"  />
                <TableColumn fx:id="colName"    text="Name"    prefWidth="110" />
                <TableColumn fx:id="colSpecies" text="Species" prefWidth="100" />
                <TableColumn fx:id="colType"    text="Type"    prefWidth="95"  />
                <TableColumn fx:id="colZone"    text="Zone"    prefWidth="130" />
                <TableColumn fx:id="colHealth"  text="Health"  prefWidth="110" />
            </columns>
            <placeholder><Label text="No animals found — click ➕ Add Animal" styleClass="text-muted" /></placeholder>
        </TableView>

        <ScrollPane fitToWidth="true" styleClass="detail-scroll">
            <VBox fx:id="detailPanel" styleClass="detail-panel" spacing="8">
                <padding><Insets top="16" right="16" bottom="16" left="16" /></padding>
                <Label text="Select an animal to view details" styleClass="text-muted" />
            </VBox>
        </ScrollPane>

    </SplitPane>
</VBox>
