<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.example.controllers.SensorsController"
      styleClass="content-root">

    <!-- ── Header ───────────────────────────────────────────────────── -->
    <HBox styleClass="zones-page-header" alignment="CENTER_LEFT" spacing="10">
        <padding><Insets top="14" right="24" bottom="14" left="24" /></padding>
        <VBox spacing="1">
            <Label text="Smart Farm" styleClass="zones-farm-name" />
            <Label text="Sensor Management" styleClass="zones-page-title" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <ComboBox fx:id="filterType"     promptText="Type"     styleClass="animals-filter-combo" prefWidth="130" />
        <ComboBox fx:id="filterSeverity" promptText="Severity" styleClass="animals-filter-combo" prefWidth="120" />
        <ComboBox fx:id="filterStatus"   promptText="Status"   styleClass="animals-filter-combo" prefWidth="120" />
        <ComboBox fx:id="filterZone"     promptText="Zone"     styleClass="animals-filter-combo" prefWidth="155" />
    </HBox>

    <!-- ── Stats cards row ───────────────────────────────────────────── -->
    <HBox spacing="16"
          style="-fx-background-color: #F5F5F3; -fx-border-color: transparent transparent #e0e0e0 transparent; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

        <VBox HBox.hgrow="ALWAYS" spacing="4"
              style="-fx-background-color: #4F46E5, #ffffff; -fx-background-insets: 0, 0 0 0 4; -fx-background-radius: 12, 0 12 12 0; -fx-border-width: 0; -fx-padding: 14 18; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.07), 8, 0, 0, 2);">
            <Label fx:id="statTotalSensors" text="—" styleClass="zones-kpi-value" />
            <Label text="TOTAL SENSORS" styleClass="zones-kpi-label" />
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="4"
              style="-fx-background-color: #DC2626, #ffffff; -fx-background-insets: 0, 0 0 0 4; -fx-background-radius: 12, 0 12 12 0; -fx-border-width: 0; -fx-padding: 14 18; -fx-effect: dropshadow(three-pass-box, rgba(220,38,38,0.12), 8, 0, 0, 2);">
            <Label fx:id="statCriticalReadings" text="—" styleClass="zones-kpi-value" />
            <Label text="CRITICAL" styleClass="zones-kpi-label" />
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="4"
              style="-fx-background-color: #D97706, #ffffff; -fx-background-insets: 0, 0 0 0 4; -fx-background-radius: 12, 0 12 12 0; -fx-border-width: 0; -fx-padding: 14 18; -fx-effect: dropshadow(three-pass-box, rgba(217,119,6,0.12), 8, 0, 0, 2);">
            <Label fx:id="statWarningReadings" text="—" styleClass="zones-kpi-value" />
            <Label text="WARNING" styleClass="zones-kpi-label" />
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="4"
              style="-fx-background-color: #16A34A, #ffffff; -fx-background-insets: 0, 0 0 0 4; -fx-background-radius: 12, 0 12 12 0; -fx-border-width: 0; -fx-padding: 14 18; -fx-effect: dropshadow(three-pass-box, rgba(22,163,74,0.12), 8, 0, 0, 2);">
            <Label fx:id="statNormalReadings" text="—" styleClass="zones-kpi-value" />
            <Label text="NORMAL" styleClass="zones-kpi-label" />
        </VBox>

    </HBox>

    <!-- ── Cards + Detail ───────────────────────────────────────────── -->
    <SplitPane VBox.vgrow="ALWAYS" dividerPositions="0.60">

        <!-- LEFT: card grid -->
        <ScrollPane fitToWidth="true" styleClass="detail-scroll">
            <VBox>
                <TilePane fx:id="sensorGrid" hgap="14" vgap="14"
                          prefTileWidth="215" styleClass="sensor-grid">
                    <padding><Insets top="16" right="16" bottom="16" left="16" /></padding>
                </TilePane>
                <VBox fx:id="gridEmptyState" alignment="CENTER" spacing="8"
                      visible="false" managed="false"
                      style="-fx-padding: 60 0 40 0;">
                    <Label text="🔍" style="-fx-font-size: 32px;" />
                    <Label text="No sensors match filters" styleClass="sensor-empty-title" />
                    <Label text="Try adjusting the filters above" styleClass="sensor-empty-sub" />
                </VBox>
            </VBox>
        </ScrollPane>

        <!-- RIGHT: detail panel -->
        <VBox styleClass="detail-panel" spacing="0">

            <!-- No-selection placeholder (visible on load) -->
            <VBox fx:id="noSelectionState" VBox.vgrow="ALWAYS" alignment="CENTER" spacing="12">
                <Label text="📡" style="-fx-font-size: 52px;" />
                <Label text="Select a sensor" styleClass="sensor-empty-title" />
                <Label text="Click a card to view details" styleClass="sensor-empty-sub" />
                <HBox alignment="CENTER" spacing="6">
                    <Label text="💡" style="-fx-font-size: 11px;" />
                    <Label text="Use filters to narrow down sensors" styleClass="sensor-empty-tip" />
                </HBox>
            </VBox>

            <!-- Detail content (shown when a sensor is selected) -->
            <VBox fx:id="detailContent" spacing="10" VBox.vgrow="ALWAYS"
                  visible="false" managed="false">
                <padding><Insets top="16" right="16" bottom="16" left="16" /></padding>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="detailTitle" text=""
                           styleClass="sensor-detail-name" HBox.hgrow="ALWAYS" wrapText="true" />
                    <Label fx:id="detailStatus" text="" />
                </HBox>

                <Label fx:id="detailZone" text="" styleClass="sensor-detail-zone" />

                <Separator />

                <HBox styleClass="detail-row" alignment="CENTER_LEFT">
                    <Label text="Last reading" styleClass="detail-key" />
                    <Label fx:id="detailReading" text="" styleClass="detail-value" wrapText="true" />
                </HBox>

                <VBox fx:id="sensorActions" spacing="8" />
                <Separator />
                <Label text="Reading History" styleClass="card-title" />
                <VBox fx:id="chartContainer" VBox.vgrow="ALWAYS" />
            </VBox>

        </VBox>

    </SplitPane>
</VBox>
