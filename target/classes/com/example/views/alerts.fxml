<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.example.controllers.AlertsController"
      styleClass="content-root">

    <!-- ── Header ───────────────────────────────────────────────────── -->
    <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="20" right="24" bottom="16" left="24" /></padding>
        <Label text="Alerts Center" styleClass="page-title" />
        <Region HBox.hgrow="ALWAYS" />
        <ComboBox fx:id="filterType"     promptText="Type"     styleClass="filter-combo" prefWidth="155" />
        <ComboBox fx:id="filterSeverity" promptText="Severity" styleClass="filter-combo" prefWidth="130" />
        <ComboBox fx:id="filterStatus"   promptText="Status"   styleClass="filter-combo" prefWidth="125" />
        <ComboBox fx:id="filterZone"     promptText="Zone"     styleClass="filter-combo" prefWidth="150" />
    </HBox>
    <Separator />

    <!-- ── Stats bar ────────────────────────────────────────────────── -->
    <HBox styleClass="stats-bar" spacing="12" alignment="CENTER_LEFT">
        <padding><Insets top="12" right="24" bottom="12" left="24" /></padding>
        <VBox styleClass="stat-card stat-accent-blue" spacing="2" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label fx:id="statTotalAlerts" text="—" styleClass="stat-value" />
            <Label text="Total Alerts" styleClass="stat-label" />
        </VBox>
        <VBox styleClass="stat-card stat-accent-red" spacing="2" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label fx:id="statCritical" text="—" styleClass="stat-value" />
            <Label text="Critical" styleClass="stat-label" />
        </VBox>
        <VBox styleClass="stat-card stat-accent-yellow" spacing="2" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label fx:id="statWarning" text="—" styleClass="stat-value" />
            <Label text="Warning" styleClass="stat-label" />
        </VBox>
        <VBox styleClass="stat-card stat-accent-green" spacing="2" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label fx:id="statResolved" text="—" styleClass="stat-value" />
            <Label text="Resolved" styleClass="stat-label" />
        </VBox>
    </HBox>
    <Separator />

    <!-- ── Table + Detail ─────────────────────────────────────────── -->
    <SplitPane VBox.vgrow="ALWAYS" dividerPositions="0.62">

        <TableView fx:id="alertTable" maxHeight="Infinity">
            <columns>
                <TableColumn fx:id="colTime"     text="Time"     prefWidth="130" />
                <TableColumn fx:id="colType"     text="Type"     prefWidth="140" />
                <TableColumn fx:id="colSeverity" text="Severity" prefWidth="90"  />
                <TableColumn fx:id="colMessage"  text="Message"  prefWidth="260" />
                <TableColumn fx:id="colStatus"   text="Status"   prefWidth="110" />
            </columns>
            <placeholder><Label text="No alerts found" styleClass="text-muted" /></placeholder>
        </TableView>

        <VBox fx:id="detailPanel" styleClass="detail-panel" spacing="12">
            <padding><Insets top="16" right="16" bottom="16" left="16" /></padding>
            <Label text="Alert Detail" styleClass="card-title" />
            <Separator />
            <Label fx:id="detailMessage" text="Select an alert to view details"
                   styleClass="text-muted" wrapText="true" />
            <HBox styleClass="detail-row" alignment="CENTER_LEFT">
                <Label text="Zone" styleClass="detail-key" />
                <Label fx:id="detailZone" text="" styleClass="detail-value" wrapText="true" />
            </HBox>
            <HBox styleClass="detail-row" alignment="CENTER_LEFT">
                <Label text="Time" styleClass="detail-key" />
                <Label fx:id="detailTimestamp" text="" styleClass="detail-value" />
            </HBox>
            <HBox styleClass="detail-row" alignment="CENTER_LEFT">
                <Label text="Status" styleClass="detail-key" />
                <Label fx:id="detailResolution" text="" styleClass="detail-value" />
            </HBox>
            <HBox styleClass="detail-row" alignment="CENTER_LEFT">
                <Label text="Trigger" styleClass="detail-key" />
                <Label fx:id="detailTrigger" text="" styleClass="detail-value" wrapText="true" />
            </HBox>
            <Separator />
            <Label text="Actions" styleClass="card-title" />
            <HBox spacing="8">
                <Button fx:id="btnAcknowledge" text="Acknowledge"
                        onAction="#acknowledgeAlert" styleClass="btn-secondary" disable="true" />
                <Button fx:id="btnResolve"     text="✔ Resolve"
                        onAction="#resolveAlert"     styleClass="btn-primary"   disable="true" />
                <Button fx:id="btnDismiss"     text="✕ Dismiss"
                        onAction="#dismissAlert"     styleClass="btn-danger"    disable="true" />
            </HBox>
        </VBox>

    </SplitPane>
</VBox>
